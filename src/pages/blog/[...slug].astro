---
import Layout from "../../layouts/Layout.astro";
import { getBlogs, getBlogDetail, type Blog } from "../../lib/microcms";

export async function getStaticPaths() {
    const response = await getBlogs({ fields: ["id"] });
    return response.contents.map((content: any) => ({
        params: {
            slug: content.id,
        },
    }));
}

const { slug } = Astro.params;
const blog = await getBlogDetail(slug as string);

if (!blog) {
    return Astro.redirect("/404");
}
---

<Layout title={blog.title}>
    <main class="container mx-auto px-4 py-8">
        <h1 class="text-3xl font-bold mb-4">{blog.title}</h1>
        <div class="text-gray-500 text-sm mb-8">
            <p>Published: {new Date(blog.publishedAt).toLocaleDateString()}</p>
            <span class="bg-gray-200 px-2 py-1 rounded text-xs"
                >{blog.category?.name}</span
            >
        </div>

        <article class="prose max-w-none" set:html={blog.content} />
    </main>
</Layout>
