---
import Layout from "../layouts/Layout.astro";

// Legal / Tokushoho Page
---

<Layout title="特定商取引法に基づく表記 - WRO 2026 Mie">
    <div class="bg-slate-50 min-h-screen">
        <main class="container mx-auto px-4 py-32 max-w-4xl relative z-10">
            <div class="text-center mb-16">
                <h1
                    class="text-4xl md:text-5xl font-bold tracking-tight mb-4 text-slate-900"
                >
                    特定商取引法に基づく表記
                </h1>
                <p class="text-slate-500">
                    Sponsor 0 プログラムおよび大会参加費に関する法的表記
                </p>
            </div>

            <div
                class="bg-white p-8 md:p-12 rounded-3xl border border-gray-200 shadow-sm overflow-hidden"
            >
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <tbody class="divide-y divide-gray-100">
                            <!-- Organization Name -->
                            <tr>
                                <th
                                    class="py-4 pr-8 font-bold text-slate-900 w-1/3 align-top"
                                    >販売業者（運営団体）</th
                                >
                                <td class="py-4 text-slate-600"
                                    >WRO Japan 2026 三重県予選会実行委員会</td
                                >
                            </tr>

                            <!-- Representative -->
                            <tr>
                                <th
                                    class="py-4 pr-8 font-bold text-slate-900 align-top"
                                    >運営統括責任者</th
                                >
                                <td class="py-4 text-slate-600">
                                    三鬼耕治<br />
                                    <span class="text-xs text-slate-400"
                                        >※ご依頼があれば遅滞なく開示いたします</span
                                    >
                                </td>
                            </tr>

                            <!-- Location -->
                            <tr>
                                <th
                                    class="py-4 pr-8 font-bold text-slate-900 align-top"
                                    >所在地</th
                                >
                                <td class="py-4 text-slate-600">
                                    〒633-0062<br />
                                    奈良県桜井市粟殿1029-6 エムズビル1F<br />
                                    <span class="text-xs text-slate-400"
                                        >※ご依頼があれば遅滞なく開示いたします</span
                                    >
                                </td>
                            </tr>

                            <!-- Contact -->
                            <tr>
                                <th
                                    class="py-4 pr-8 font-bold text-slate-900 align-top"
                                    >連絡先</th
                                >
                                <td class="py-4 text-slate-600">
                                    info@miraido.net<br />
                                    0744-48-3603<br />
                                    <span class="text-xs text-slate-400"
                                        >※電話番号はご請求をいただいた場合、遅滞なく開示いたします</span
                                    >
                                </td>
                            </tr>

                            <!-- Price -->
                            <tr>
                                <th
                                    class="py-4 pr-8 font-bold text-slate-900 align-top"
                                    >販売価格（協賛金・参加費）</th
                                >
                                <td class="py-4 text-slate-600"
                                    >各申し込みページに表示された金額（表示価格は消費税込み）とします。</td
                                >
                            </tr>

                            <!-- Additional Fees -->
                            <tr>
                                <th
                                    class="py-4 pr-8 font-bold text-slate-900 align-top"
                                    >商品代金以外の必要料金</th
                                >
                                <td class="py-4 text-slate-600">
                                    銀行振込の場合、振込手数料はお客様のご負担となります。<br
                                    />
                                    大会参加時の交通費・機材費等は自己負担となります。
                                </td>
                            </tr>

                            <!-- Payment Methods -->
                            <tr>
                                <th
                                    class="py-4 pr-8 font-bold text-slate-900 align-top"
                                    >お支払い方法</th
                                >
                                <td class="py-4 text-slate-600">
                                    クレジットカード決済、または銀行振込
                                </td>
                            </tr>

                            <!-- Timing -->
                            <tr>
                                <th
                                    class="py-4 pr-8 font-bold text-slate-900 align-top"
                                    >支払時期</th
                                >
                                <td class="py-4 text-slate-600">
                                    クレジットカード：各カード会社の引き落とし日<br
                                    />
                                    銀行振込：お申し込みから7日以内
                                </td>
                            </tr>

                            <!-- Product Delivery -->
                            <tr>
                                <th
                                    class="py-4 pr-8 font-bold text-slate-900 align-top"
                                    >引渡し時期</th
                                >
                                <td class="py-4 text-slate-600">
                                    ご入金確認後、直ちに協賛者として登録・掲載（または参加確定）いたします。
                                </td>
                            </tr>

                            <!-- Returns / Cancel -->
                            <tr>
                                <th
                                    class="py-4 pr-8 font-bold text-slate-900 align-top"
                                    >返品・キャンセルについて</th
                                >
                                <td class="py-4 text-slate-600">
                                    性質上、ご入金後の返金・キャンセルはお受けしておりません。<br
                                    />
                                    大会が中止となった場合等の対応については、別途規定に従います。
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="text-center mt-12">
                <a
                    href="/"
                    class="text-slate-500 hover:text-blue-600 transition-colors font-medium"
                    >&larr; トップへ戻る</a
                >
            </div>
        </main>
    </div>
</Layout>
