---
import Layout from "../layouts/Layout.astro";
import { getBlogs, type Blog } from "../lib/microcms";
import ThreeScene from "../components/ThreeScene";
import ContactForm from "../components/ContactForm";

// Fetch blogs with filtering for 'wro' target site
const { contents: blogs } = await getBlogs({
	filters: "targetSites[contains]wro",
});
---

<Layout>
	<ThreeScene client:only="react" />

	<div class="relative w-full overflow-x-hidden z-10">
		<!-- Hero Section -->
		<section
			class="h-screen w-full flex flex-col items-center justify-center relative overflow-hidden"
		>
			<!-- Text Overlay -->
			<div class="z-20 text-center px-4 mix-blend-multiply">
				<h1
					class="reveal-text text-6xl md:text-9xl font-bold tracking-tighter mb-6 bg-gradient-to-b from-amber-400 to-purple-700 bg-clip-text text-transparent transform"
				>
					Robots Meet Culture
				</h1>
				<p
					class="text-lg md:text-2xl text-slate-600 font-normal tracking-wide animate-fade-in-delay opacity-0 max-w-2xl mx-auto"
				>
					WRO Japan 2026 公認 三重予選会
					<br />
					<span
						class="text-sm md:text-base opacity-80 mt-2 block text-slate-500"
					>
						ロボット技術はいかにして芸術と文化を形作り、守り、発展させることができるのか？
					</span>
				</p>
			</div>

			<!-- Scroll Indicator -->
			<div
				class="absolute bottom-12 left-1/2 transform -translate-x-1/2 z-20 opacity-70 animate-bounce"
			>
				<svg
					width="24"
					height="24"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					class="text-slate-900"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M7 13l5 5 5-5M7 6l5 5 5-5"></path>
				</svg>
			</div>
		</section>

		<main class="container mx-auto px-4 py-24 space-y-48 relative z-20">
			<!-- News Section -->
			<section>
				<div
					class="flex flex-col md:flex-row justify-between items-end mb-12 border-b border-gray-200 pb-4"
				>
					<h2
						class="text-4xl md:text-5xl font-bold tracking-tight text-slate-900"
					>
						最新情報
					</h2>
					<a
						href="/news"
						class="text-blue-600 hover:text-blue-500 transition-colors mt-4 md:mt-0"
						>記事一覧へ &rarr;</a
					>
				</div>

				<div
					class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
				>
					{
						blogs.length > 0 ? (
							blogs.map((blog) => (
								<a
									href={`/blog/${blog.id}`}
									class="group block bg-white/80 backdrop-blur-sm rounded-2xl overflow-hidden hover:scale-[1.02] hover:shadow-xl transition-all duration-500 border border-gray-100 hover:border-blue-200 shadow-sm"
								>
									<div class="aspect-video w-full bg-gray-100 relative overflow-hidden">
										{blog.thumbnail ? (
											<img
												src={blog.thumbnail.url}
												alt={blog.title}
												width={blog.thumbnail.width}
												height={blog.thumbnail.height}
												class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
											/>
										) : (
											<div class="w-full h-full flex items-center justify-center text-gray-400">
												画像なし
											</div>
										)}
									</div>
									<div class="p-8">
										<p class="text-sm text-slate-500 mb-3">
											{new Date(
												blog.publishedAt,
											).toLocaleDateString()}
										</p>
										<h3 class="text-xl font-bold text-slate-900 group-hover:text-blue-600 transition-colors line-clamp-2">
											{blog.title}
										</h3>
									</div>
								</a>
							))
						) : (
							<p class="text-slate-500">まだ記事がありません。</p>
						)
					}
				</div>
			</section>

			<!-- Competitions Section -->
			<section class="border-t border-gray-200 pt-24">
				<h2
					class="text-4xl md:text-6xl font-bold tracking-tight mb-16 text-center text-slate-900"
				>
					競技について
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					<!-- RoboMission Link -->
					<a
						href="/mission"
						class="block bg-white/60 border border-gray-200 rounded-3xl p-10 hover:bg-white hover:shadow-2xl hover:border-blue-200 transition-all duration-300 group shadow-sm backdrop-blur-sm"
					>
						<h3
							class="text-3xl font-bold mb-4 text-slate-900 group-hover:text-blue-600 transition-colors flex items-center"
						>
							RoboMission
							<svg
								class="w-6 h-6 ml-4 opacity-0 group-hover:opacity-100 transform translate-x-2 group-hover:translate-x-0 transition-all"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								><path d="M5 12h14M12 5l7 7-7 7"></path></svg
							>
						</h3>
						<p class="text-slate-600 leading-relaxed mb-6">
							WROの代表的な競技カテゴリーです。チームは自律型ロボットを設計・プログラムし、フィールド上の課題を解決。正確性とスピードを競います。
						</p>
						<ul class="text-sm text-slate-500 space-y-2">
							<li class="flex items-center">
								<span
									class="w-1.5 h-1.5 bg-blue-500 rounded-full mr-2"
								></span>エレメンタリー部門(小学生)
							</li>
							<li class="flex items-center">
								<span
									class="w-1.5 h-1.5 bg-blue-500 rounded-full mr-2"
								></span>ジュニア部門（中学生）
							</li>
							<li class="flex items-center">
								<span
									class="w-1.5 h-1.5 bg-blue-500 rounded-full mr-2"
								></span>シニア部門（高校生）
							</li>
						</ul>
					</a>

					<!-- RoboSports Link -->
					<a
						href="/sports"
						class="block bg-white/60 border border-gray-200 rounded-3xl p-10 hover:bg-white hover:shadow-2xl hover:border-purple-200 transition-all duration-300 group shadow-sm backdrop-blur-sm"
					>
						<h3
							class="text-3xl font-bold mb-4 text-slate-900 group-hover:text-purple-600 transition-colors flex items-center"
						>
							RoboSports
							<svg
								class="w-6 h-6 ml-4 opacity-0 group-hover:opacity-100 transform translate-x-2 group-hover:translate-x-0 transition-all"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								><path d="M5 12h14M12 5l7 7-7 7"></path></svg
							>
						</h3>
						<p class="text-slate-600 leading-relaxed mb-6">
							WRO唯一の対戦型競技です。エキサイティングなダブルステニスのように正確性と戦略を駆使して互いに得点を競います。
						</p>
						<ul class="text-sm text-slate-500 space-y-2">
							<li class="flex items-center">
								<span
									class="w-1.5 h-1.5 bg-purple-500 rounded-full mr-2"
								></span>ロボスポーツ（テニス）
							</li>
						</ul>
					</a>
				</div>
			</section>

			<!-- Venue Section -->
			<section class="border-t border-gray-200 pt-24">
				<h2
					class="text-4xl md:text-6xl font-bold tracking-tight mb-16 text-center text-slate-900"
				>
					開催地: 三重県尾鷲市
				</h2>
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
					<!-- Owase City Info -->
					<div class="space-y-8">
						<div>
							<h3 class="text-2xl font-bold mb-4 text-slate-900">
								豊かな自然と歴史のまち
							</h3>
							<p class="text-slate-600 leading-relaxed">
								♪おわせぇ〜よいとこぉ〜
								あさぁひぃ〜をう〜けてヨーイソレ🎶
								の尾鷲節で知られる三重県尾鷲市は、世界遺産「熊野古道伊勢路」を有する歴史ある港まちです。黒潮の恩恵を受ける豊かな海と、深い山々に囲まれたこの地は、日本有数の降水量を誇り、その雨が育む「尾鷲ヒノキ」は全国的に知られ、「尾鷲ヒノキ林業」は、日本農業遺産第一号に認定されています。
							</p>
						</div>
						<div>
							<h3 class="text-2xl font-bold mb-4 text-slate-900">
								競技会場 : 三重県立熊野古道センター
							</h3>
							<div
								class="bg-white p-8 rounded-3xl border border-gray-200 shadow-sm"
							>
								<p class="text-slate-600 mb-6 leading-relaxed">
									世界遺産・熊野古道のビジターセンターとして建設された、尾鷲ヒノキ135mm角無垢材のみで建築された美しい木造建築です。開放的な空間で、歴史と未来が交差するロボット競技会開催にふさわしい舞台です。
								</p>
								<div class="space-y-4 text-sm text-slate-500">
									<div class="flex items-start">
										<span
											class="font-bold w-20 flex-shrink-0 text-slate-900"
											>開催場所</span
										>
										<span
											>三重県立熊野古道センター　大ホール</span
										>
									</div>
									<div class="flex items-start">
										<span
											class="font-bold w-20 flex-shrink-0 text-slate-900"
											>開催日時</span
										>
										<span>7月20日(月・祝日)※海の日</span>
									</div>
									<div class="flex items-start">
										<span
											class="font-bold w-20 flex-shrink-0 text-slate-900"
											>開催時間</span
										>
										<span>10:00 - 17:00 (予定)</span>
									</div>
									<div class="flex items-start">
										<span
											class="font-bold w-20 flex-shrink-0 text-slate-900"
											>住所</span
										>
										<span
											>〒519-3625 三重県尾鷲市向井12-4</span
										>
									</div>
									<div class="flex items-start">
										<span
											class="font-bold w-20 flex-shrink-0 text-slate-900"
										></span>
										<span
											>駐車場(無料)、バリアフリー対応</span
										>
									</div>
								</div>
							</div>
						</div>
					</div>

					<!-- Access Info -->
					<div
						class="bg-slate-50 p-8 md:p-10 rounded-3xl border border-gray-200"
					>
						<h3
							class="text-2xl font-bold mb-6 text-slate-900 flex items-center"
						>
							アクセス
							<svg
								class="w-6 h-6 ml-2 text-slate-400"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								><path
									d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
								></path><circle cx="12" cy="10" r="3"
								></circle></svg
							>
						</h3>

						<div class="space-y-8">
							<div>
								<h4
									class="font-bold text-slate-900 mb-2 flex items-center"
								>
									<span
										class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mr-3 text-sm"
										>車</span
									>
									自動車でお越しの方
								</h4>
								<ul
									class="space-y-2 text-slate-600 text-sm ml-11"
								>
									<li>
										紀勢自動車道「尾鷲北IC」より車で約10分
									</li>
									<li>
										熊野尾鷲道路「尾鷲南IC」より車で約15分
									</li>
									<li>
										※ 無料駐車場完備（普通車・大型バス対応）
									</li>
								</ul>
							</div>

							<div>
								<h4
									class="font-bold text-slate-900 mb-2 flex items-center"
								>
									<span
										class="w-8 h-8 bg-green-100 text-green-600 rounded-full flex items-center justify-center mr-3 text-sm"
										>電</span
									>
									公共交通機関でお越しの方
								</h4>
								<ul
									class="space-y-4 text-slate-600 text-sm ml-11"
								>
									<li>
										<span
											class="block font-medium text-slate-800 mb-1"
											>JR紀勢本線「尾鷲駅」下車</span
										>
										<ul
											class="list-disc list-inside pl-2 space-y-1 text-xs"
										>
											<li>タクシー利用：約10分</li>
											<li>
												バス利用：尾鷲市ふれあいバス「紀伊松本行き」にて「熊野古道センター前」下車（約13分）
											</li>
										</ul>
									</li>
								</ul>
							</div>

							<!-- Google Maps -->
							<div
								class="rounded-2xl overflow-hidden shadow-sm border border-gray-100 mt-6 h-64"
							>
								<iframe
									src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1544.150645064848!2d136.19614486663248!3d34.07399895208571!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6006443c0a52df25%3A0x6a2c270d4c82c67f!2z5LiJ6YeN55yM56uL54aK6YeO5Y-k6YGT44K744Oz44K_44O8!5e0!3m2!1sja!2sjp!4v1700000000000!5m2!1sja!2sjp"
									width="100%"
									height="100%"
									style="border:0;"
									allowfullscreen=""
									loading="lazy"
									referrerpolicy="no-referrer-when-downgrade"
								></iframe>
							</div>

							<div class="pt-6 border-t border-gray-200">
								<a
									href="https://kumanokodocenter.com/"
									target="_blank"
									rel="noopener noreferrer"
									class="inline-flex items-center text-blue-600 font-bold hover:text-blue-500 transition-colors"
								>
									熊野古道センター公式サイトへ
									<svg
										class="w-4 h-4 ml-1"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										><path
											d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
										></path><polyline
											points="15 3 21 3 21 9"
										></polyline><line
											x1="10"
											y1="14"
											x2="21"
											y2="3"></line></svg
									>
								</a>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- About / Sponsor 0 Section -->
			<section
				class="py-24 border-t border-gray-200 relative overflow-hidden"
			>
				<div
					class="absolute inset-0 bg-gradient-to-b from-transparent to-slate-50 pointer-events-none"
				>
				</div>
				<div class="relative z-10 max-w-4xl mx-auto text-center">
					<span
						class="text-blue-600 font-semibold tracking-wider text-sm uppercase mb-4 block"
						>パートナーシップのご案内</span
					>
					<h2
						class="text-4xl md:text-5xl font-bold mb-8 tracking-tight text-slate-900"
					>
						"Sponsor 0" とは？
					</h2>
					<p class="text-xl text-slate-600 leading-relaxed mb-12">
						私たちは、商業的なしがらみなしに子供たちの未来を支援することを信条としています。「スポンサー０（ゼロ）」プログラムは、広告宣伝よりも社会貢献を重視するパートナー様と共に歩む取り組みです。
					</p>
					<a
						href="/about"
						class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-slate-900 transition-all duration-200 bg-white border border-gray-200 rounded-full hover:bg-slate-900 hover:text-white hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-slate-900"
					>
						私たちのミッションについて
					</a>
				</div>
			</section>

			<!-- Contact Section -->
			<section class="max-w-4xl mx-auto text-center">
				<h2
					class="text-4xl md:text-6xl font-bold tracking-tight mb-8 text-slate-900"
				>
					お問い合わせ
				</h2>
				<p class="text-xl text-slate-600 mb-14">
					大会に関するご質問やご相談がございましたら、お気軽にお問い合わせください。
				</p>

				<div
					class="text-left bg-white/80 backdrop-blur-xl p-8 md:p-12 rounded-3xl border border-gray-200 shadow-2xl"
				>
					<ContactForm client:visible />
				</div>
			</section>
		</main>

		<!-- Footer -->
		<footer class="border-t border-gray-200 py-12 mt-24 bg-slate-50">
			<div
				class="container mx-auto px-4 text-center text-slate-500 text-sm"
			>
				<div
					class="flex justify-center gap-6 mb-6 text-xs font-medium tracking-wide"
				>
					<a
						href="/privacy"
						class="hover:text-slate-900 transition-colors"
						>プライバシーポリシー</a
					>
					<a
						href="/legal"
						class="hover:text-slate-900 transition-colors"
						>特定商取引法に基づく表記</a
					>
				</div>
				<p>
					<a
						href="https://miraido.net/"
						target="_blank"
						rel="noopener noreferrer"
						class="hover:text-blue-600 transition-colors"
					>
						【 MIRAIDO PROJECT 】&copy; 2026 360inc. All rights
						reserved.
					</a>
				</p>
			</div>
		</footer>
	</div>
</Layout>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	gsap.registerPlugin(ScrollTrigger);

	// Text Reveal Logic
	gsap.fromTo(
		".reveal-text",
		{
			opacity: 0,
			y: 100,
			scale: 0.8,
			filter: "blur(10px)",
		},
		{
			opacity: 1,
			y: 0,
			scale: 1,
			filter: "blur(0px)",
			duration: 4.0, // Slow and dramatic
			ease: "power2.out",
			delay: 0.5,
		},
	);

	// Fade in delay
	gsap.to(".animate-fade-in-delay", {
		opacity: 1,
		y: 0,
		duration: 1,
		delay: 0.8,
		ease: "power2.out",
	});
</script>

<style>
	/* Removed custom keyframes in favor of GSAP */
</style>
