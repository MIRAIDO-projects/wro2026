---
import { SEO } from "astro-seo";
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonical?: string;
	noindex?: boolean;
	article?: boolean;
	publishedTime?: string;
	modifiedTime?: string;
}

const {
	title = "WRO 2026 三重県予選大会ポータル",
	description = "WRO 2026（World Robotics Olympiad）三重県予選大会の公式ポータルサイト。テーマ「Robots Meet Culture」のもと、競技情報・会場案内・最新ニュースをお届けします。",
	image = "/og-image.jpg",
	canonical,
	noindex = false,
	article = false,
	publishedTime,
	modifiedTime,
} = Astro.props;

// Canonical / OG URL: prefer the explicit prop, otherwise the current page URL.
const canonicalURL = canonical ?? Astro.url.href;
// Absolute URL for the OG/Twitter image (resolve relative paths against site).
const imageURL = new URL(image, Astro.site ?? Astro.url).href;
const siteURL = (Astro.site ?? new URL("/", Astro.url)).href.replace(/\/$/, "");

// Schema.org JSON-LD Construction
type SchemaNode = Record<string, unknown>;
const schema: { "@context": string; "@graph": SchemaNode[] } = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Organization",
			"@id": `${siteURL}/#organization`,
			name: "WRO Japan 2026 三重県予選会実行委員会",
			url: siteURL,
			logo: `${siteURL}/logo.png`,
		},
		{
			"@type": "WebSite",
			"@id": `${siteURL}/#website`,
			url: siteURL,
			name: "WRO 2026 三重県予選大会ポータル",
			publisher: { "@id": `${siteURL}/#organization` },
		},
	],
};

if (article) {
	schema["@graph"].push({
		"@type": "Article",
		headline: title.split("|")[0].trim(),
		description: description,
		image: imageURL,
		url: canonicalURL,
		datePublished: publishedTime,
		dateModified: modifiedTime || publishedTime,
		author: { "@id": `${siteURL}/#organization` },
		publisher: { "@id": `${siteURL}/#organization` },
	});
}

import CustomCursor from "../components/CustomCursor.astro";
import FloatingArt from "../components/FloatingArt.astro";
import CookieBanner from "../components/CookieBanner.astro";
import Footer from "../components/Footer.astro";
---

<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<!-- Fonts loaded via Google Fonts CDN (single source; @fontsource is not imported). -->
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap"
			rel="stylesheet"
		/>

		<SEO
			title={title}
			description={description}
			canonical={canonicalURL}
			noindex={noindex}
			nofollow={noindex}
			openGraph={{
				basic: {
					title: title,
					type: article ? "article" : "website",
					image: imageURL,
					url: canonicalURL,
				},
				optional: {
					locale: "ja_JP",
					description: description,
				},
			}}
			twitter={{
				card: "summary_large_image",
				creator: "@wro2026",
			}}
			extend={{
				meta: [
					{ name: "twitter:image", content: imageURL },
					{ name: "twitter:title", content: title },
					{ name: "twitter:description", content: description },
				],
			}}
		/>

		<script type="application/ld+json" set:html={JSON.stringify(schema)} />
	</head>
	<body
		class="antialiased text-slate-900 selection:bg-blue-100 cursor-none"
		style="background: transparent;"
	>
		<CustomCursor />
		<FloatingArt />
		<slot />
		<Footer />

		<script>
			import Lenis from "lenis";
			import { gsap } from "gsap";
			import { ScrollTrigger } from "gsap/ScrollTrigger";

			gsap.registerPlugin(ScrollTrigger);

			const lenis = new Lenis({
				duration: 1.2,
				easing: (t: number) =>
					Math.min(1, 1.001 - Math.pow(2, -10 * t)),
				orientation: "vertical",
				gestureOrientation: "vertical",
				smoothWheel: true,
			});

			function raf(time: number) {
				lenis.raf(time);
				requestAnimationFrame(raf);
			}

			requestAnimationFrame(raf);
		</script>
		<CookieBanner />
	</body>
</html>

<style is:global>
	/* Fonts loaded via CDN in head */

	:root {
		--font-body:
			"Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			Roboto, Oxygen, Ubuntu, Cantarell, "Open Sans", "Helvetica Neue",
			sans-serif;
	}

	html {
		font-family: var(--font-body);
		background-color: transparent;
		color: #0f172a; /* slate-900 */
	}

	body {
		margin: 0;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	html.lenis,
	html.lenis body {
		height: auto;
	}

	.lenis.lenis-smooth {
		scroll-behavior: auto !important;
	}

	.lenis.lenis-smooth [data-lenis-prevent] {
		overscroll-behavior: contain;
	}

	.lenis.lenis-stopped {
		overflow: hidden;
	}

	.lenis.lenis-scrolling iframe {
		pointer-events: none;
	}
</style>
