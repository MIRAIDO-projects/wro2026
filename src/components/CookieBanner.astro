---
import { type HTMLAttributes } from "astro/types";

interface CookieConsentData {
    agreeLabel: string;
    denyLabel: string;
}

const cookieData: CookieConsentData = {
    agreeLabel: "同意する",
    denyLabel: "拒否する",
};

interface Props extends HTMLAttributes<"div"> {}

const { class: className, ...props } = Astro.props;
---

<div
    id="cookie-banner"
    class:list={[
        // z-[10000] keeps the banner above CustomCursor (z-[9999])
        "fixed bottom-0 left-0 z-[10000] w-full",
        "bg-white/95 backdrop-blur-sm",
        "border-t border-gray-200/50 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)]",
        "invisible opacity-0 translate-y-full", // Tailwind classes for initial state (FOUC prevention)
        className,
    ]}
    role="dialog"
    aria-live="polite"
    aria-label="Cookie 同意"
    {...props}
>
    <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
        <div
            class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between"
        >
            <div class="flex-1">
                <p class="text-sm text-gray-600 leading-relaxed max-w-3xl">
                    当サイトでは、UX向上およびGoogle Tag Manager /
                    Google Analytics 等による利用状況の解析のためにCookieを使用します。
                    同意いただくと、より良いブラウジング体験を提供できます。詳細は<a
                        href="/privacy"
                        class="text-indigo-600 underline underline-offset-2 hover:text-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded"
                        >プライバシーポリシー</a
                    >をご確認ください。
                </p>
            </div>

            <div class="flex items-center gap-3 shrink-0">
                <button
                    id="btn-deny"
                    type="button"
                    class="rounded-lg border border-gray-300 px-4 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition-colors focus:outline-none focus:ring-2 focus:ring-gray-300 focus:ring-offset-2"
                >
                    {cookieData.denyLabel}
                </button>
                <button
                    id="btn-agree"
                    type="button"
                    class="rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-indigo-700 transition-colors shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
                >
                    {cookieData.agreeLabel}
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    import { gsap } from "gsap";

    const STORAGE_KEY = "site_consent_status";
    const BANNER_ID = "cookie-banner";
    const BTN_AGREE_ID = "btn-agree";
    const BTN_DENY_ID = "btn-deny";

    type ConsentStatus = "granted" | "denied";

    const initCookieBanner = () => {
        const banner = document.getElementById(BANNER_ID);
        const btnAgree = document.getElementById(BTN_AGREE_ID);
        const btnDeny = document.getElementById(BTN_DENY_ID);

        if (!banner || !btnAgree || !btnDeny) return;

        // 1. Already consented (granted/denied): keep it hidden via Tailwind invisible classes.
        //    We intentionally avoid display:none so GSAP autoAlpha can manage visibility cleanly.
        if (localStorage.getItem(STORAGE_KEY)) {
            return;
        }

        // 2. GTM Handler — consent flow logic is preserved as-is.
        const updateGtm = (status: ConsentStatus) => {
            if (typeof window.gtag === "function") {
                window.gtag("consent", "update", {
                    ad_storage: status,
                    ad_user_data: status,
                    ad_personalization: status,
                    analytics_storage: status,
                });
            }
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({ event: "consent_updated" });
        };

        // Click Handler — granted => GTM consent update + dynamic insert (via updateGtm),
        // denied => only localStorage is persisted. Logic unchanged.
        const handleConsent = (status: ConsentStatus) => {
            localStorage.setItem(STORAGE_KEY, status);
            updateGtm(status);

            // Animate Out — autoAlpha hides (visibility:hidden) only after the tween completes,
            // preventing any flash and keeping the element interaction-free once gone.
            gsap.to(banner, {
                y: "100%",
                autoAlpha: 0,
                duration: 0.5,
                ease: "power3.in",
            });
        };

        btnAgree.onclick = () => handleConsent("granted");
        btnDeny.onclick = () => handleConsent("denied");

        // 3. Animate In (Delay 1.0s). fromTo forces visibility override (autoAlpha) for FOUC-safe reveal.
        setTimeout(() => {
            if (localStorage.getItem(STORAGE_KEY)) return;

            gsap.fromTo(
                banner,
                { y: "100%", autoAlpha: 0 },
                { y: 0, autoAlpha: 1, duration: 1.0, ease: "power3.out" },
            );
        }, 1000);
    };

    // Run on every page load (initial load + Astro View Transitions)
    document.addEventListener("astro:page-load", initCookieBanner);
</script>
