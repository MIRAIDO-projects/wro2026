---
// Floating Art Background - paintings flow randomly in the background with scroll
// Using GSAP for smooth, reliable animations
---

<div
    id="floating-art-container"
    class="fixed inset-0 pointer-events-none overflow-hidden"
    style="z-index: 5;"
>
    <!-- Image 1 -->
    <div class="floating-art">
        <img
            src="/images/bg001.jpg"
            alt="Art Background 1"
            class="floating-img"
        />
    </div>

    <!-- Image 2 -->
    <div class="floating-art">
        <img
            src="/images/bg002.jpg"
            alt="Art Background 2"
            class="floating-img"
        />
    </div>

    <!-- Image 3 -->
    <div class="floating-art">
        <img
            src="/images/bg003.jpg"
            alt="Art Background 3"
            class="floating-img"
        />
    </div>

    <!-- Image 4 -->
    <div class="floating-art">
        <img
            src="/images/bg004.jpg"
            alt="Art Background 4"
            class="floating-img"
        />
    </div>

    <!-- Image 5 -->
    <div class="floating-art">
        <img
            src="/images/bg005.jpg"
            alt="Art Background 5"
            class="floating-img"
        />
    </div>

    <!-- Image 6 -->
    <div class="floating-art">
        <img
            src="/images/bg006.jpg"
            alt="Art Background 6"
            class="floating-img"
        />
    </div>

    <!-- Duplicates for more density if needed, picking random ones -->
    <div class="floating-art">
        <img
            src="/images/bg001.jpg"
            alt="Art Background 1 Rep"
            class="floating-img"
        />
    </div>

    <div class="floating-art">
        <img
            src="/images/bg003.jpg"
            alt="Art Background 3 Rep"
            class="floating-img"
        />
    </div>

    <div class="floating-art">
        <img
            src="/images/bg005.jpg"
            alt="Art Background 5 Rep"
            class="floating-img"
        />
    </div>
</div>

<style>
    .floating-art {
        position: absolute;
        opacity: 0;
        transform: scale(0.5) rotate(0deg);
        will-change: transform, opacity;
        top: 0;
        left: 0;
    }

    .floating-img {
        width: 350px;
        height: auto;
        border-radius: 8px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2);
        border: 8px solid #fff;
        transition: transform 0.3s ease;
        background-color: #eee; /* Placeholder color */
    }

    @media (max-width: 768px) {
        .floating-img {
            width: 180px;
            border-width: 4px;
        }
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const container = document.getElementById("floating-art-container");
    const arts = document.querySelectorAll(".floating-art");

    if (container && arts.length > 0) {
        // Initialize random positions
        arts.forEach((art) => {
            const element = art as HTMLElement;
            element.style.left = `${Math.random() * 80 + 5}%`;
            element.style.top = `${Math.random() * 80 + 10}%`;
        });

        // Animate based on scroll
        arts.forEach((art, i) => {
            const element = art as HTMLElement;

            // 1. Continuous Floating
            gsap.to(element, {
                y: "random(-40, 40)",
                x: "random(-20, 20)",
                rotation: "random(-6, 6)",
                duration: "random(6, 12)",
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });

            // 2. Scroll Triggered Appearance
            gsap.timeline({
                scrollTrigger: {
                    trigger: "body",
                    start: `top+=${i * 300} top`, // Staggered start
                    end: `+=1200`,
                    toggleActions: "play reverse play reverse",
                    scrub: 1,
                },
            })
                .fromTo(
                    element,
                    { opacity: 0, scale: 0.6, y: 150 },
                    {
                        opacity: 0.9,
                        scale: 1,
                        y: -150,
                        duration: 1,
                        ease: "power2.out",
                    },
                )
                .to(element, {
                    opacity: 0,
                    scale: 0.8,
                    y: -250,
                    duration: 1,
                    ease: "power2.in",
                });
        });
    }
</script>
