---
// Floating Art Background
// Fixed Z-Index to 5 to avoid blocking content.
// Image visibility prioritized as background element.
---

<div
    id="floating-art-container"
    class="fixed inset-0 pointer-events-none overflow-hidden"
    style="z-index: 5;"
>
    {/* Statically output potential images. Browser handles loading/error. */}
    {
        Array.from({ length: 9 }).map((_, i) => {
            const num = String(i + 1).padStart(3, "0");
            const src = `/images/bg${num}.jpg`;
            return (
                <img
                    src={src}
                    class="floating-art visually-hidden"
                    alt=""
                    onerror="this.style.display='none'"
                    data-index={i}
                />
            );
        })
    }
</div>

<style>
    .floating-art {
        position: absolute;
        width: 300px;
        height: auto;
        opacity: 0;
        border-radius: 8px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        border: 6px solid rgba(255, 255, 255, 0.9);
        display: block;
        object-fit: cover;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    @media (max-width: 768px) {
        .floating-art {
            width: 150px;
            border-width: 3px;
        }
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const images = document.querySelectorAll(".floating-art");

    const shuffled = Array.from(images).sort(() => 0.5 - Math.random());
    const selected = shuffled.slice(0, 6);

    shuffled.slice(6).forEach((el) => el.remove());

    selected.forEach((img, i) => {
        const el = img as HTMLElement;

        const x = Math.random() * 80 + 10;
        const y = Math.random() * 80 + 10;
        const rot = (Math.random() - 0.5) * 60;
        const scale = 0.5 + Math.random() * 0.5;

        el.style.left = `${x}%`;
        el.style.top = `${y}%`;

        gsap.set(el, {
            xPercent: -50,
            yPercent: -50,
            y: 200,
            scale: scale * 0.5,
            rotation: rot,
            opacity: 0,
        });

        gsap.to(el, {
            x: `random(-30, 30)`,
            rotation: `random(${rot - 10}, ${rot + 10})`,
            duration: `random(6, 12)`,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut",
        });

        const triggerStart = window.innerHeight * 0.5 + i * 200;

        gsap.timeline({
            scrollTrigger: {
                trigger: "body",
                start: `${triggerStart}px top`,
                end: `+=${window.innerHeight * 1.5}`,
                scrub: 1,
                toggleActions: "play reverse play reverse",
            },
        })
            .to(el, {
                y: -100,
                scale: scale,
                opacity: 1,
                duration: 1,
                ease: "power2.out",
            })
            .to(el, {
                y: -300,
                opacity: 0,
                scale: scale * 1.2,
                duration: 1,
                ease: "power2.in",
            });
    });

    // Cleanup: kill all ScrollTriggers before an Astro View Transition swap to
    // prevent stale triggers / duplicate instances and memory leaks.
    document.addEventListener("astro:before-swap", () => {
        ScrollTrigger.getAll().forEach((t) => t.kill());
    });
</script>
